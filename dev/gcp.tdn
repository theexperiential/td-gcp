			},
			"custom_pars": {
				"Creds": [
					{
						"name": "Privatekey",
						"style": "File",
						"label": "Private Key File",
						"help": "Path to your Google Cloud service account JSON key file. Changing this automatically triggers a reconnect."
					},
					{
						"name": "Databaseid",
						"style": "Str",
						"label": "Database ID",
						"help": "Firestore database ID. Leave blank for the default database. Only needed for named databases.",
						"value": "(default)"
					}
				],
				"Sync": [
					{
						"name": "Enablelistener",
						"style": "Toggle",
						"label": "Enable Listener",
						"value": true
					},
					{
						"name": "Enablewriteback",
						"style": "Toggle",
						"label": "Enable Write-Back",
						"value": true
					},
					{
						"name": "Collections",
						"style": "Str",
						"label": "Collections (space-sep)",
						"startSection": true
					},
					{
						"name": "Filterdocs",
						"style": "Str",
						"label": "Filter Docs (space-sep)",
						"startSection": true
					},
					{
						"name": "Filterdocsmode",
						"style": "Menu",
						"label": "Doc Filter Mode",
						"default": "include",
						"menuNames": ["include", "exclude"],
						"menuLabels": ["Include", "Exclude"]
					},
					{
						"name": "Filterfields",
						"style": "Str",
						"label": "Filter Fields (space-sep)",
						"startSection": true
					},
					{
						"name": "Filterfieldsmode",
						"style": "Menu",
						"label": "Field Filter Mode",
						"default": "exclude",
						"menuNames": ["exclude", "include"],
						"menuLabels": ["Exclude", "Include"]
					}
				],
				"Conn": [
					{
						"name": "Autoconnect",
						"style": "Toggle",
						"label": "Auto Connect",
						"help": "Automatically connect to Firestore after bootstrap completes. If off, you must pulse Connect manually.",
						"value": true
					},
					{
						"name": "Circuitfailurethreshold",
						"style": "Int",
						"label": "Circuit Failure Threshold",
						"help": "Number of consecutive failures before the circuit breaker opens and blocks further attempts until timeout.",
						"value": 5
					},
					{
						"name": "Circuittimeout",
						"style": "Float",
						"label": "Circuit Timeout (s)",
						"help": "Seconds to wait before the circuit breaker resets from open to half-open, allowing a retry.",
						"value": 60
					},
					{
						"name": "Backoffbase",
						"style": "Float",
						"label": "Backoff Base",
						"help": "Base multiplier (seconds) for exponential backoff between reconnect attempts.",
						"value": 2
					},
					{
						"name": "Backoffmax",
						"style": "Float",
						"label": "Backoff Max (s)",
						"help": "Maximum delay (seconds) between reconnect attempts, capping exponential backoff.",
						"value": 300
					}
				],
				"Cache": [
					{
						"name": "Enablecache",
						"style": "Toggle",
						"label": "Enable Cache",
						"help": "Enable SQLite-backed offline write queue. Writes made while disconnected are persisted and retried on reconnect.",
						"value": true
					},
					{
						"name": "Cachepath",
						"style": "Folder",
						"label": "Cache Folder",
						"help": "Folder for the SQLite cache database. Defaults to the project folder if blank.",
						"value": "cache"
					},
					{
						"name": "Cachehydrate",
						"style": "Toggle",
						"label": "Hydrate on Start",
						"help": "On connect, populate local tableDATs from the SQLite cache before listeners start. Gives you instant data while waiting for Firestore.",
						"value": true
					}
				],
				"Callbacks": [
					{
						"name": "Createcallbacksdat",
						"style": "Pulse",
						"label": "Create",
						"help": "Create a new callbacks DAT pre-filled with stub functions for onFirestoreChange, onWriteComplete, and onConnectionStateChange."
					},
					{
						"name": "Callbacksdat",
						"style": "DAT",
						"label": "Callbacks DAT",
						"help": "Path to a DAT with callback functions (onFirestoreChange, onWriteComplete, onConnectionStateChange). Leave blank to disable."
					},
					{
						"name": "Logop",
						"style": "DAT",
						"label": "External Log DAT",
						"help": "Path to an external DAT to receive log entries (e.g. a fifoDAT). In addition to the internal log and textport output."
					}
				],
				"Controls": [
					{
						"name": "Flushdirty",
						"style": "Pulse",
						"label": "Flush Dirty",
						"help": "Push all documents with _dirty=1 to Firestore. Useful for batch-pushing edits or retrying after invalid JSON was fixed."
					},
					{
						"name": "Connect",
						"style": "Pulse",
						"help": "Connect to Firestore using the current credentials. Starts listeners if Enable Listener is on."
					},
					{
						"name": "Disconnect",
						"style": "Pulse",
						"help": "Cleanly disconnect from Firestore and stop all listeners."
					},
					{
						"name": "Reset",
						"style": "Pulse",
						"help": "Full teardown and reinitialize — clears all state, reconnects from scratch."
					},
					{
						"name": "Flushqueue",
						"style": "Pulse",
						"label": "Flush Write Queue",
						"help": "Force-retry all pending offline writes in the queue."
					}
				],
