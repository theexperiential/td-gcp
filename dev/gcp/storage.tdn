			},
			{
				"name": "Remotepath",
				"style": "Str",
				"label": "Remote Path",
				"help": "Remote prefix in the bucket (e.g. media/). All upload, download, and sync operations are relative to this path.",
				"value": "test/"
			},
			{
				"name": "Makepublic",
				"style": "Toggle",
				"label": "Make Public",
				"help": "When on, uploaded blobs are made public automatically. Can be overridden per-call via the Upload() method's make_public argument."
			},
			{
				"name": "Deleteremoteorphans",
				"style": "Toggle",
				"label": "Delete Remote Orphans",
				"startSection": true,
				"help": "During upload or sync, delete remote blobs under Remote Path that don't exist locally. Effectively makes local the source of truth."
			},
			{
				"name": "Deletelocalorphans",
				"style": "Toggle",
				"label": "Delete Local Orphans",
				"help": "During download or sync, delete local files under Local Path that don't exist remotely. Effectively makes remote the source of truth."
			},
			{
				"name": "Maxconcurrent",
				"style": "Int",
				"label": "Max Concurrent",
				"startSection": true,
				"help": "Maximum number of simultaneous upload/download operations. Additional transfers are queued and submitted as active ones complete.",
				"value": 3
			}
		],
		"Conn": [
			{
				"name": "Autoconnect",
				"style": "Toggle",
				"label": "Auto Connect",
				"help": "Automatically connect to Firebase Storage after bootstrap completes. If off, you must pulse Connect manually.",
				"value": true
			},
			{
				"name": "Circuitfailurethreshold",
				"style": "Int",
				"label": "Circuit Failure Threshold",
				"help": "Number of consecutive failures before the circuit breaker opens and blocks further attempts until timeout.",
				"value": 5
			},
			{
				"name": "Circuittimeout",
				"style": "Float",
				"label": "Circuit Timeout (s)",
				"help": "Seconds to wait before the circuit breaker resets from open to half-open, allowing a retry.",
				"value": 60
			},
			{
				"name": "Backoffbase",
				"style": "Float",
				"label": "Backoff Base",
				"help": "Base multiplier (seconds) for exponential backoff between reconnect attempts.",
				"value": 2
			},
			{
				"name": "Backoffmax",
				"style": "Float",
				"label": "Backoff Max (s)",
				"help": "Maximum delay (seconds) between reconnect attempts, capping exponential backoff.",
				"value": 300
			}
