				"name": "Upload",
				"style": "Pulse",
				"help": "Upload all files from Local Path to Remote Path, preserving subfolder structure."
			},
			{
				"name": "Download",
				"style": "Pulse",
				"help": "Download all files from Remote Path to Local Path, preserving subfolder structure."
			},
			{
				"name": "Sync",
				"style": "Pulse",
				"help": "Bidirectional sync -- uploads missing/newer local files and downloads missing/newer remote files."
			},
			{
				"name": "Connect",
				"style": "Pulse",
				"startSection": true,
				"help": "Connect to Firebase Storage using the current credentials."
			},
			{
				"name": "Disconnect",
				"style": "Pulse",
				"help": "Cleanly disconnect from Firebase Storage."
			},
			{
				"name": "Reset",
				"style": "Pulse",
				"help": "Full teardown -- clears transfers, resets circuit breaker, disconnects."
			},
